# Copy to .env and fill in values you use.

SKOUT_PROFILE=gardner-farm

# Trash Nothing — register at https://trashnothing.com/developer (login → register app → API key)
TRASHNOTHING_API_KEY=

# Nextdoor (optional) — https://developer.nextdoor.com
# NEXTDOOR_CLIENT_ID=
# NEXTDOOR_CLIENT_SECRET=

# Email alerts (optional) — Gmail app password
# Used for Auto Skout "don't pass up" truck deal alerts when profile email.enabled=true
GMAIL_USER=
GMAIL_APP_PASSWORD=
ALERT_EMAIL_TO=

# GitHub — one-time; scripts reuse this and save to macOS Keychain (repo scope)
# https://github.com/settings/tokens/new?scopes=repo
GITHUB_TOKEN=
